#!/bin/bash

# Git pre-push hook that checks for merge conflicts with the remote branch
# and automatically spawns Claude to fix them before pushing.
#
# Installation:
#   cp hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# Requirements:
#   - Claude Code CLI must be installed and available as 'claude'

set -e

remote="$1"
url="$2"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[pre-push]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[pre-push]${NC} $1"
}

log_error() {
    echo -e "${RED}[pre-push]${NC} $1"
}

# Check if claude CLI is available
if ! command -v claude &> /dev/null; then
    log_warn "Claude CLI not found, skipping merge conflict check"
    exit 0
fi

# Read the push information from stdin
while read local_ref local_oid remote_ref remote_oid; do
    # Skip delete operations
    if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # Extract branch name from ref
    branch_name="${local_ref#refs/heads/}"
    remote_branch="${remote_ref#refs/heads/}"

    log_info "Checking for merge conflicts with ${remote}/${remote_branch}..."

    # Fetch the latest remote state
    git fetch "$remote" "$remote_branch" 2>/dev/null || {
        log_warn "Could not fetch remote branch, skipping conflict check"
        continue
    }

    # Check if remote branch exists
    if ! git rev-parse --verify "$remote/$remote_branch" &>/dev/null; then
        log_info "Remote branch doesn't exist yet, no conflicts possible"
        continue
    fi

    # Find the merge base
    merge_base=$(git merge-base "$local_oid" "$remote/$remote_branch" 2>/dev/null) || {
        log_warn "Could not determine merge base, skipping conflict check"
        continue
    }

    # If remote hasn't changed since our base, no conflicts possible
    if [ "$merge_base" = "$remote_oid" ] || [ "$merge_base" = "$(git rev-parse $remote/$remote_branch)" ]; then
        log_info "No merge conflicts detected"
        continue
    fi

    # Try a test merge to check for conflicts
    log_info "Remote has new commits, checking for potential conflicts..."

    # Save current state
    current_branch=$(git rev-parse --abbrev-ref HEAD)
    stash_result=$(git stash push -m "pre-push-hook-temp" 2>&1) || true
    has_stash=false
    if [[ "$stash_result" != *"No local changes"* ]]; then
        has_stash=true
    fi

    # Create a temporary branch for test merge
    temp_branch="pre-push-conflict-check-$$"
    git checkout -b "$temp_branch" "$local_oid" --quiet 2>/dev/null

    # Attempt the merge
    merge_output=$(git merge "$remote/$remote_branch" --no-commit --no-ff 2>&1) || true
    merge_status=$?

    # Check for conflicts
    conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)

    if [ -n "$conflicts" ]; then
        log_warn "Merge conflicts detected in the following files:"
        echo "$conflicts" | while read file; do
            echo "  - $file"
        done

        # Abort the test merge
        git merge --abort 2>/dev/null || true
        git checkout "$current_branch" --quiet
        git branch -D "$temp_branch" --quiet 2>/dev/null || true

        # Restore stash if we had one
        if [ "$has_stash" = true ]; then
            git stash pop --quiet 2>/dev/null || true
        fi

        log_info "Spawning Claude to resolve merge conflicts..."

        # Create a prompt for Claude to fix the conflicts
        conflict_prompt="There are merge conflicts between my local branch '$branch_name' and the remote branch '$remote/$remote_branch'.

The conflicting files are:
$conflicts

Please:
1. Merge the remote changes into my current branch
2. Resolve any merge conflicts intelligently, preserving the intent of both changes
3. Stage the resolved files
4. Create a merge commit with an appropriate message

After resolving, I will retry the push."

        # Run Claude in interactive mode to fix conflicts
        echo ""
        echo "=========================================="
        echo "Claude will now attempt to fix the merge conflicts."
        echo "=========================================="
        echo ""

        # Use claude CLI to fix conflicts
        if claude --print "$conflict_prompt"; then
            log_info "Claude has attempted to resolve the conflicts."
            log_info "Please review the changes and retry your push if satisfied."
        else
            log_error "Claude encountered an error while resolving conflicts."
        fi

        # Exit with error to prevent push - user should review and retry
        exit 1
    else
        # No conflicts - clean up
        git merge --abort 2>/dev/null || git reset --hard HEAD 2>/dev/null || true
        git checkout "$current_branch" --quiet
        git branch -D "$temp_branch" --quiet 2>/dev/null || true

        # Restore stash if we had one
        if [ "$has_stash" = true ]; then
            git stash pop --quiet 2>/dev/null || true
        fi

        log_info "No merge conflicts detected"
    fi
done

exit 0
